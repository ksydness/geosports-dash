# Supabase — get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://ryikqqhbuyiiiukqemru.supabase.co
SUPABASE_SERVICE_ROLE_KEY=     # Settings → API → service_role key (keep secret!)

